{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "crons": [
    {
      "path": "/api/auto-blog-generate",
      "schedule": "0 14 * * *"
    }
  ],
  "rewrites": [
    { "source": "/signage", "destination": "/signage.html" },
    { "source": "/wayfinding", "destination": "/wayfinding.html" },
    { "source": "/marketing", "destination": "/marketing.html" },
    { "source": "/paint-protection-film", "destination": "/paint-protection-film.html" },
    { "source": "/window-tint", "destination": "/window-tint.html" },
    { "source": "/ceramic-coating", "destination": "/ceramic-coating.html" },
    { "source": "/services/paint-protection-film", "destination": "/paint-protection-film.html" },
    { "source": "/services/window-tint", "destination": "/window-tint.html" },
    { "source": "/services/ceramic-coating", "destination": "/ceramic-coating.html" },
    { "source": "/commercial-wraps", "destination": "/commercial-wraps.html" },
    { "source": "/((?!api/|@vite|@react-refresh|src/|node_modules/|.*\\.[a-zA-Z0-9]+$).*)", "destination": "/index.html" }
  ]
}
