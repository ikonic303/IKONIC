{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "crons": [
    {
      "path": "/api/blog?action=auto-generate",
      "schedule": "0 14 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "(www\\.)?ikonicmarketing303\\.com"
        }
      ],
      "destination": "https://ikonic303.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/blog-posts",
      "destination": "/api/blog?action=list"
    },
    {
      "source": "/api/blog-post",
      "destination": "/api/blog?action=post"
    },
    {
      "source": "/api/publish-blog",
      "destination": "/api/blog?action=publish"
    },
    {
      "source": "/api/generate-post",
      "destination": "/api/blog?action=generate-post"
    },
    {
      "source": "/api/auto-blog-generate",
      "destination": "/api/blog?action=auto-generate"
    },
    {
      "source": "/signage",
      "destination": "/signage.html"
    },
    {
      "source": "/wayfinding",
      "destination": "/wayfinding.html"
    },
    {
      "source": "/marketing",
      "destination": "/marketing.html"
    },
    {
      "source": "/paint-protection-film",
      "destination": "/paint-protection-film.html"
    },
    {
      "source": "/window-tint",
      "destination": "/window-tint.html"
    },
    {
      "source": "/ceramic-coating",
      "destination": "/ceramic-coating.html"
    },
    {
      "source": "/services/paint-protection-film",
      "destination": "/paint-protection-film.html"
    },
    {
      "source": "/services/window-tint",
      "destination": "/window-tint.html"
    },
    {
      "source": "/services/ceramic-coating",
      "destination": "/ceramic-coating.html"
    },
    {
      "source": "/commercial-wraps",
      "destination": "/commercial-wraps.html"
    },
    {
      "source": "/post/:slug",
      "destination": "/index.html"
    },
    {
      "source": "/proof-manager",
      "destination": "/index.html"
    },
    {
      "source": "/proof/:token",
      "destination": "/index.html"
    },
    {
      "source": "/viral-bot",
      "destination": "/index.html"
    },
    {
      "source": "/viral-bot/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/((?!api/|@vite|@react-refresh|src/|node_modules/|.*\\.[a-zA-Z0-9]+$).*)",
      "destination": "/404.html"
    }
  ]
}