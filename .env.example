# ── AI Website Generator ──────────────────────────────────────────────────────
# Set these in Vercel → Project → Settings → Environment Variables.
# Never commit real secrets. This file documents the names only.

# HARD KILL SWITCH. Set to 0 to disable the generator + deposit instantly, with no
# deploy. Any other value (or unset) leaves it enabled.
GENERATOR_ENABLED=1

# Deposit gate. Unset/any value = a paid Square deposit is required before a concept
# is generated. Set to 0 to run the generator as a FREE lead magnet (still rate
# limited). Flip this to change the business model without a code change.
GENERATOR_REQUIRE_DEPOSIT=1

# Deposit amount in USD (default 250).
GENERATOR_DEPOSIT_USD=250

# ── Gemini (concept generation — this is the spend the guard protects) ────────
GEMINI_API_KEY=

# ── Square (payments) ─────────────────────────────────────────────────────────
# We use SQUARE, not Stripe (Josh 2026-07-20). Same keys as api/create-checkout-session.ts.
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
# 'sandbox' routes to connect.squareupsandbox.com; anything else = production.
SQUARE_ENV=

# ── Redis (rate limiting + one-time deposit tokens) ───────────────────────────
# ALREADY CONFIGURED on this project as UPSTASH_REDIS_REST_* — guard.ts accepts either
# naming, so nothing new needs provisioning. WITHOUT one of these pairs, one-time-use
# tokens cannot be enforced across instances and the deposit flow refuses to take
# payment rather than accept a replayable receipt.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# (Vercel KV naming, equivalent — either pair works)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Canonical origin used to build the Square return URL. Defaults to the request
# origin, then https://ikonic303.com.
SITE_ORIGIN=https://ikonic303.com

# ── Existing ──────────────────────────────────────────────────────────────────
RESEND_API_KEY=

# ── Added 2026-07-21 (security audit) ─────────────────────────────────────────

# Proof-system Supabase project. The URL + anon key used to be HARDCODED in
# src/lib/supabase.ts in this PUBLIC repo, pointed at a project that no longer exists
# (NXDOMAIN). An anon key is meant to ship in the browser, so this is not a secret —
# but it must be rotatable without a code change.
# ⚠️ Before pointing this at a project, verify RLS on `proofs` and `annotations` is
# TOKEN-SCOPED. /proof/:token is public and unauthenticated, so RLS is the whole
# security model; a `USING (true)` policy exposes the entire customer list.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# GHL webhook-trigger for proof lifecycle events. For an inbound GHL webhook the URL IS
# the credential; it used to be hardcoded client-side and shipped in the public bundle.
# ⚠️ The old trigger (…/23d15f93-…) is BURNED — public since 2026-04-16 and in the git
# history of a public repo. Create a NEW trigger, put it here, and DELETE the old one.
GHL_PROOF_WEBHOOK_URL=

# Per-feature kill switches (default ON when unset; set to 0 to disable instantly with
# no deploy). Separate from GENERATOR_ENABLED so turning the generator off does not
# stop the shop taking orders.
CHECKOUT_ENABLED=1
REVIEWS_ENABLED=1
STICKER_NOTIFY_ENABLED=1
PROOF_WEBHOOK_ENABLED=1

# Optional business ceiling on self-serve checkout. Unset defaults to a $100k absurdity
# backstop (real jobs reach ~$60k+, so a lower cap would reject genuine orders). Set this
# if orders above a threshold should route to a phone call instead.
CHECKOUT_MAX_USD=
