# ── AI Website Generator — required environment variables ─────────────────────
# Copy the relevant keys into Vercel (Project → Settings → Environment Variables)
# and into a local .env / .env.local for development. Do NOT commit real secrets.

# Kill-switch. Set to 0 to hard-disable the generator (deposit + generation).
# Any other value (or unset) leaves it enabled.
GENERATOR_ENABLED=1

# ── Gemini (AI generation) ────────────────────────────────────────────────────
GEMINI_API_KEY=

# ── Stripe ($250 deposit) ─────────────────────────────────────────────────────
# Secret key from https://dashboard.stripe.com/apikeys (use a TEST key for staging).
STRIPE_SECRET_KEY=

# ── Cloudflare Turnstile (bot protection) ─────────────────────────────────────
# Public site key is exposed to the browser (Vite var); secret stays server-side.
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Vercel KV / Upstash Redis (one-time-use + rate limiting) ──────────────────
# Provided automatically by the Vercel KV integration (already used by ops-*).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── GoHighLevel (lead routing + agreement gate) ───────────────────────────────
# Private integration / API token with contacts, opportunities, documents scopes.
GHL_API_TOKEN=
# IKONIC SALES pipeline ids. TODO: fill with the real pipeline + stage ids.
GHL_PIPELINE_ID=
GHL_PIPELINE_STAGE_ID=
# Website-build service-agreement document template id. TODO: confirm.
GHL_AGREEMENT_TEMPLATE_ID=
# Staging escape hatch for the agreement gate: set to 0 to treat sessions as
# signed while the GHL Documents signing webhook is being wired. Leave unset
# (enforced) in production.
AGREEMENT_ENFORCED=1

# ── Lead notification email (Resend, verified domain) ─────────────────────────
RESEND_API_KEY=
# Verified-domain sender — never the Resend sandbox (onboarding@resend.dev).
LEAD_EMAIL_FROM="Ikonic AI Website Generator <noreply@ikonicmarketing303.com>"
LEAD_EMAIL_TO=info@ikonicmarketing303.com
